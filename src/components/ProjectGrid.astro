---
import { mockProjects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section class="p-6 md:p-12 py-20 min-h-screen">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-y-24 md:gap-x-8 md:gap-y-32" id="projects-grid">
    {mockProjects.map((project, index) => (
      <ProjectCard project={project} index={index} />
    ))}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    const projects = document.querySelectorAll('.project-card');
    
    projects.forEach((project) => {
      gsap.to(project, {
        scrollTrigger: {
          trigger: project,
          start: "top 85%", // Animation triggers when the top of the card is at 85% of viewport
          once: true
        },
        y: 0,
        opacity: 1,
        duration: 1.2,
        ease: "power3.out"
      });
    });
  });
</script>
